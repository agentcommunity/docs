{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "mkdir -p .output && echo '{}' > .output/config.json",
  "installCommand": "echo 'No install needed'",
  "outputDirectory": ".output",
  "redirects": [
    {
      "source": "/rss.xml",
      "has": [{ "type": "host", "value": "blog.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/blog/rss.xml",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "blog.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/blog",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "blog.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/blog/:path*",
      "permanent": true
    },
    {
      "source": "/api/search",
      "has": [{ "type": "host", "value": "docs.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/api/content-search",
      "permanent": true
    },
    {
      "source": "/docs/:path*",
      "has": [{ "type": "host", "value": "docs.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/docs/:path*",
      "permanent": true
    },
    {
      "source": "/docs",
      "has": [{ "type": "host", "value": "docs.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/docs",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "docs.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/docs",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "docs.agentcommunity.org" }],
      "destination": "https://agentcommunity.org/docs/:path*",
      "permanent": true
    }
  ]
}
